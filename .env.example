# =============================================================================
# Slick Enterprises HQ - Environment Configuration (v1)
# =============================================================================
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# SECURITY: `.env` is git-ignored. NEVER commit real secrets.
# Agents are NOT allowed to read this file directly. Only scoped services
# (gateway, bridges, bots) load these values via the shared config loader.
# =============================================================================

# ---- Core / general ----------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
TZ=Europe/London

# ---- Local Web UI auth (v1: single shared password, no user DB) --------------
# Used by slick-ui to gate access. Keep this private.
UI_ADMIN_PASSWORD=poloi
# Shared secret the UI uses to talk to the gateway.
GATEWAY_API_TOKEN=dev-gateway-token-change-me

# ---- Gateway / API ------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
# Base URL other *containers* use to reach the gateway (Docker DNS service name).
# Use http://localhost:8000 only when running services directly on the host.
GATEWAY_PUBLIC_URL=http://slick-gateway:8000
# Frontend -> gateway base URL (browser / Next.js on the host uses localhost).
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ---- Postgres -----------------------------------------------------------------
POSTGRES_USER=slick
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=slick_hq
POSTGRES_HOST=slick-postgres
POSTGRES_PORT=5432
# SQLAlchemy URL (async). Host = docker service name when running in compose.
DATABASE_URL=postgresql+asyncpg://slick:change-me-postgres@slick-postgres:5432/slick_hq
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://slick:change-me-postgres@slick-postgres:5432/slick_hq

# ---- Redis (queue + pub/sub) --------------------------------------------------
REDIS_HOST=slick-redis
REDIS_PORT=6379
REDIS_URL=redis://slick-redis:6379/0

# ---- Model provider ----------------------------------------------------------
# cursor    -> Cursor SDK (Composer); billed to your Cursor subscription.
# anthropic -> direct Anthropic API (pay-per-token).
MODEL_PROVIDER=cursor
# Set to true to run without real API calls (mock responses, zero cost).
# Flip to false ONCE the chosen provider's key is filled in.
MODEL_MOCK_MODE=true

# ---- Cursor SDK (Composer) ----------------------------------------------------
# Mint a User API key at https://cursor.com/dashboard/integrations (prefix crsr_).
# SDK runs use the same plan/request pool as the IDE; spend shows in the Cursor
# usage dashboard under the "SDK" tag (no per-call dollar figure is returned).
CURSOR_API_KEY=
# local = run Composer on this machine; cloud = Cursor-hosted VM + GitHub PRs.
CURSOR_RUNTIME=local
CURSOR_WORKSPACE_DIR=/workspace
CURSOR_MODEL_CHEAP=auto
CURSOR_MODEL_SMART=composer-2.5
# Dashboard usage sync (Individual Max/Pro). Copy from Cursor browser session or
# sqlite key cursorAuth/accessToken — see docs/08-cost-control.md. Never commit.
CURSOR_ACCESS_TOKEN=
CURSOR_WORKOS_SESSION_TOKEN=
CURSOR_REFRESH_TOKEN=
# Poll interval for cost-controller to sync Cursor dashboard usage (seconds).
CURSOR_USAGE_SYNC_INTERVAL_SEC=900

# ---- Anthropic (only used when MODEL_PROVIDER=anthropic) ----------------------
ANTHROPIC_API_KEY=
MODEL_CHEAP=claude-haiku-4
MODEL_SMART=claude-sonnet-4

# ---- Cost control -------------------------------------------------------------
# With MODEL_PROVIDER=cursor these act as a USAGE budget surfaced in the dashboard;
# authoritative dollar spend lives in your Cursor usage dashboard. With
# MODEL_PROVIDER=anthropic they are hard per-token dollar limits.
COST_BUDGET_USD=200
# Alert every N dollars of spend.
COST_ALERT_STEP_USD=20
# When budget is hit, pause all LLM work EXCEPT Sheriff S messages.
COST_HARD_CAP_USD=200

# ---- Self-building engine (autonomous build bounds) ---------------------------
# Specialised-agent tasks running at once within a build.
BUILD_MAX_CONCURRENCY=3
# Hard ceiling on Composer runs per build (planner + builders + evaluators).
BUILD_MAX_COMPOSER_RUNS=40
# Wall-clock timeout for one build, in minutes.
BUILD_TIMEOUT_MIN=60
# Rework cycles allowed for a failing task before it is marked blocked.
BUILD_MAX_REWORK_ATTEMPTS=3

# Hard ceiling on Composer runs per owner command in #biz-<slug> (operate mode).
OPS_MAX_COMPOSER_RUNS_PER_COMMAND=5

# ---- Discord ------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_NAME=Sheriff S
# Channel names the bot ensures exist (comma-separated, no '#').
DISCORD_CHANNELS=slick-control,sheriff-s,agent-updates,approvals,costs,github-prs,system-alerts,business-ideas

# ---- GitHub -------------------------------------------------------------------
GITHUB_PAT=
GITHUB_OWNER=
GITHUB_REPO=slick-enterprises
GITHUB_DEFAULT_BRANCH=main
# Agents must never push directly to main unless mode allows it.
GITHUB_ALLOW_DIRECT_PUSH_TO_MAIN=false

# ---- OpenClaw bridge (multi-agent comms / routing) ----------------------------
# Cursor-first: HQ's orchestrator + Redis queue handle routing, so the bridge runs
# its built-in in-memory router (mock). Set to "live" only after wiring real OpenClaw.
OPENCLAW_MODE=mock
OPENCLAW_BASE_URL=http://slick-openclaw-bridge:8100
OPENCLAW_API_KEY=

# ---- Hermes / coding-engine bridge --------------------------------------------
# cursor = Composer-backed (default, billed to Cursor), mock = canned, live = Hermes.
HERMES_MODE=cursor
HERMES_BASE_URL=http://slick-hermes-bridge:8200
HERMES_API_KEY=
HERMES_DATA_DIR=/data/hermes

# ---- Sandbox runner -----------------------------------------------------------
SANDBOX_BASE_URL=http://slick-sandbox-runner:8300
# Dangerous command patterns are always blocked unless explicitly approved.
SANDBOX_REQUIRE_APPROVAL_FOR_DANGEROUS=true
