# =============================================================================
# Slick Enterprises HQ - Environment Configuration (v1)
# =============================================================================
# Copy this file to `.env` and fill in real values.
#   cp .env.example .env
#
# SECURITY: `.env` is git-ignored. NEVER commit real secrets.
# Agents are NOT allowed to read this file directly. Only scoped services
# (gateway, bridges, bots) load these values via the shared config loader.
# =============================================================================

# ---- Core / general ----------------------------------------------------------
ENV=development
LOG_LEVEL=INFO
TZ=Europe/London

# ---- Local Web UI auth (v1: single shared password, no user DB) --------------
# Used by slick-ui to gate access. Keep this private.
UI_ADMIN_PASSWORD=change-me-please
# Shared secret the UI uses to talk to the gateway.
GATEWAY_API_TOKEN=dev-gateway-token-change-me

# ---- Gateway / API ------------------------------------------------------------
GATEWAY_HOST=0.0.0.0
GATEWAY_PORT=8000
GATEWAY_PUBLIC_URL=http://localhost:8000
# Frontend -> gateway base URL (used by Next.js server components / API routes)
NEXT_PUBLIC_GATEWAY_URL=http://localhost:8000

# ---- Postgres -----------------------------------------------------------------
POSTGRES_USER=slick
POSTGRES_PASSWORD=change-me-postgres
POSTGRES_DB=slick_hq
POSTGRES_HOST=slick-postgres
POSTGRES_PORT=5432
# SQLAlchemy URL (async). Host = docker service name when running in compose.
DATABASE_URL=postgresql+asyncpg://slick:change-me-postgres@slick-postgres:5432/slick_hq
# Sync URL used by Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://slick:change-me-postgres@slick-postgres:5432/slick_hq

# ---- Redis (queue + pub/sub) --------------------------------------------------
REDIS_HOST=slick-redis
REDIS_PORT=6379
REDIS_URL=redis://slick-redis:6379/0

# ---- Model provider (Anthropic first; provider-agnostic design) ---------------
MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Cheapest capable model for routine work (routing, summaries, clarifying Qs).
MODEL_CHEAP=claude-haiku-4
# High-quality model for architecture / coding / review tasks.
MODEL_SMART=claude-sonnet-4
# Set to true to run without real API calls (mock responses, zero cost).
MODEL_MOCK_MODE=true

# ---- Cost control -------------------------------------------------------------
# Budget for the whole prototype, in USD.
COST_BUDGET_USD=200
# Alert every N dollars of spend.
COST_ALERT_STEP_USD=20
# When budget is hit, pause all LLM work EXCEPT Sheriff S messages.
COST_HARD_CAP_USD=200

# ---- Discord ------------------------------------------------------------------
DISCORD_BOT_TOKEN=
DISCORD_GUILD_ID=
DISCORD_BOT_NAME=Sheriff S
# Channel names the bot ensures exist (comma-separated, no '#').
DISCORD_CHANNELS=slick-control,sheriff-s,agent-updates,approvals,costs,github-prs,system-alerts,business-ideas

# ---- GitHub -------------------------------------------------------------------
GITHUB_PAT=
GITHUB_OWNER=
GITHUB_REPO=slick-enterprises
GITHUB_DEFAULT_BRANCH=main
# Agents must never push directly to main unless mode allows it.
GITHUB_ALLOW_DIRECT_PUSH_TO_MAIN=false

# ---- OpenClaw bridge (multi-agent comms / routing) ----------------------------
OPENCLAW_MODE=mock
OPENCLAW_BASE_URL=http://slick-openclaw-bridge:8100
OPENCLAW_API_KEY=

# ---- Hermes bridge (coding / sandbox / skill engine) --------------------------
HERMES_MODE=mock
HERMES_BASE_URL=http://slick-hermes-bridge:8200
HERMES_API_KEY=
HERMES_DATA_DIR=/data/hermes

# ---- Sandbox runner -----------------------------------------------------------
SANDBOX_BASE_URL=http://slick-sandbox-runner:8300
# Dangerous command patterns are always blocked unless explicitly approved.
SANDBOX_REQUIRE_APPROVAL_FOR_DANGEROUS=true
