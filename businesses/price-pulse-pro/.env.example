# =============================================================================
# Price Pulse Pro — environment configuration
# =============================================================================
# Copy to `.env` in this directory:
#   cp .env.example .env
# =============================================================================

# ---- Database (PostgreSQL) ---------------------------------------------------
# Async URL for FastAPI / SQLAlchemy async engine.
DATABASE_URL=postgresql+asyncpg://pricepulse:pricepulse@localhost:5433/pricepulse
# Sync URL for Alembic migrations.
DATABASE_URL_SYNC=postgresql+psycopg://pricepulse:pricepulse@localhost:5433/pricepulse

# ---- Redis (job queue) -------------------------------------------------------
REDIS_URL=redis://localhost:6380/0

# ---- Slack alerts ------------------------------------------------------------
# Incoming webhook for price-change notifications.
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/T000/B000/XXXXXXXX

# ---- API (backend base URL) --------------------------------------------------
# Used by the frontend, worker, and scheduler when calling the FastAPI service.
API_BASE_URL=http://localhost:8000

# ---- Scheduler ---------------------------------------------------------------
# How often the scheduler enqueues scrape jobs for all competitors (seconds).
SCHEDULE_INTERVAL_SECONDS=3600

# ---- Logging -----------------------------------------------------------------
LOG_LEVEL=INFO

# ---- Service ports (host) ----------------------------------------------------
BACKEND_PORT=8000
FRONTEND_PORT=3100
POSTGRES_PORT=5433
REDIS_PORT=6380

# ---- Postgres container credentials ----------------------------------------
POSTGRES_USER=pricepulse
POSTGRES_PASSWORD=pricepulse
POSTGRES_DB=pricepulse

# ---- Frontend (browser-visible API URL) ------------------------------------
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
